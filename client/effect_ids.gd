class_name EffectIds
## Stable ids for cosmetic, client-side effects. Entities request an effect by id
## (decoupled from client/), and EffectSpawner maps the id to a scene. Add a new
## id here + a scene in EffectSpawner.EFFECTS to introduce a new skill effect.

const SLASH := 0
const BOLT_IMPACT := 1
const DASH_PUFF := 2
const HEAL_SPARKLE := 3
const SLAM_RING := 4
const BOSS_SMASH_RING := 5
const BOSS_SUMMON_BURST := 6
const NOVA_RING := 7
